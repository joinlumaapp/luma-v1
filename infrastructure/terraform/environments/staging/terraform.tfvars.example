# ─── Staging Environment Configuration ─────────────────────
# Copy this file to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars to git!

aws_region         = "eu-west-1"
availability_zones = ["eu-west-1a", "eu-west-1b"]

# Database (required — no default for password)
db_password = "CHANGE_ME_staging_secure_password"

# ACM Certificate (optional — leave empty to skip HTTPS)
# certificate_arn = "arn:aws:acm:eu-west-1:123456789:certificate/xxx"

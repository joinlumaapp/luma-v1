# ─────────────────────────────────────────────────────────
# LUMA V1 — Production Environment Variables
# This is a TEMPLATE. Copy to .env.production and fill in
# real values. NEVER commit the actual .env.production file.
# ─────────────────────────────────────────────────────────

# ─── Application ────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=luma

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGINS=https://luma.dating,https://api.luma.dating

# ─── Database (PostgreSQL — RDS) ────────────────────────
# Use the RDS endpoint from Terraform output
DATABASE_URL=postgresql://luma_prod:CHANGE_ME@luma-prod.xxxxxxxxxx.eu-west-1.rds.amazonaws.com:5432/luma_prod?connection_limit=20&pool_timeout=10&sslmode=require

# ─── Redis (ElastiCache) ────────────────────────────────
REDIS_URL=rediss://luma-prod.xxxxxx.0001.euw1.cache.amazonaws.com:6379

# ─── Elasticsearch (OpenSearch) ─────────────────────────
ELASTICSEARCH_URL=https://luma-prod-xxxxxxxxxx.eu-west-1.es.amazonaws.com

# ─── JWT Authentication ────────────────────────────────
# CRITICAL: Generate unique 256-bit keys for production!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_AND_REPLACE_ME
JWT_REFRESH_SECRET=GENERATE_AND_REPLACE_ME
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ─── SMS Provider (Netgsm — Turkey) ────────────────────
# Primary SMS provider for Turkish market launch
NETGSM_USERCODE=CHANGE_ME
NETGSM_PASSWORD=CHANGE_ME
NETGSM_MSGHEADER=LUMA

# ─── Firebase (Push Notifications) ─────────────────────
FIREBASE_PROJECT_ID=CHANGE_ME
FIREBASE_CLIENT_EMAIL=CHANGE_ME
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# ─── AWS (S3 / CloudFront — Photo Storage) ─────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=luma-uploads-prod
CLOUDFRONT_URL=https://cdn.luma.dating

# ─── Sentry (Error Tracking) ───────────────────────────
SENTRY_DSN=CHANGE_ME
SENTRY_ENVIRONMENT=production

# ─── Mixpanel (Analytics) ──────────────────────────────
MIXPANEL_TOKEN=CHANGE_ME

# ─── Google (OAuth / Play Store) ───────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ─── Admin & Moderation ────────────────────────────────
ADMIN_USER_IDS=CHANGE_ME
MODERATOR_USER_IDS=CHANGE_ME

# ─── Revenue Cat (In-App Purchases) ────────────────────
REVENUECAT_API_KEY=CHANGE_ME
REVENUECAT_WEBHOOK_SECRET=CHANGE_ME

# ─────────────────────────────────────────────────────────
# LUMA V1 — Backend Environment Variables
# Copy to .env and fill in the values for your environment.
# Required vars are uncommented; optional vars are commented.
# ─────────────────────────────────────────────────────────

# ─── Application ────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=luma
# APP_VERSION is read from package.json automatically

# ─── CORS ───────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Database (PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://luma:luma_dev_2024@localhost:5432/luma_dev?connection_limit=10&pool_timeout=10

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ──────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── JWT Authentication ────────────────────────────────
# IMPORTANT: Change these in production! Use 256-bit random keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-256-bit-key
JWT_REFRESH_SECRET=change-this-to-another-random-256-bit-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── SMS Provider (Twilio) ─────────────────────────────
# Required for phone verification in production.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# ─── SMS Provider (Netgsm — Turkey) ────────────────────
# Alternative SMS provider for Turkish phone numbers.
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_MSGHEADER=LUMA

# ─── Firebase (Push Notifications) ─────────────────────
# Required for push notifications in production.
# FIREBASE_PROJECT_ID=luma-app-xxxxx
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@luma-app-xxxxx.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── AWS (S3 / CloudFront — Photo Storage) ─────────────
# Required for photo uploads in production.
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_S3_BUCKET=luma-photos-prod
# AWS_S3_VOICE_BUCKET=luma-voice-prod
# AWS_CLOUDFRONT_URL=https://dxxxxxxxxxx.cloudfront.net

# ─── Sentry (Error Tracking) ───────────────────────────
# Optional: no-op if not set (see SentryModule).
# SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx
# SENTRY_ENVIRONMENT=development

# ─── Mixpanel (Analytics) ──────────────────────────────
# Optional: analytics events are dropped if not set.
# MIXPANEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google (OAuth / Play Store) ───────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Apple (Sign in with Apple / App Store) ─────────────
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=

# ─── Admin & Moderation ────────────────────────────────
# Comma-separated user IDs with elevated privileges.
# ADMIN_USER_IDS=uuid-1,uuid-2
# MODERATOR_USER_IDS=uuid-3,uuid-4

# ─── Revenue Cat (In-App Purchases) ────────────────────
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=

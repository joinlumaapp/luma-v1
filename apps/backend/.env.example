# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/luma_dev

# ─── JWT Authentication ─────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-key
JWT_REFRESH_SECRET=change-this-to-another-random-256-bit-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Application ────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# ─── Rate Limiting ──────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── External Services (optional — mocked in dev) ───

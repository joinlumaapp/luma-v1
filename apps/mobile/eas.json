{
  "cli": {
    "version": ">= 13.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.11.0",
      "env": {
        "SENTRY_DSN": "PLACEHOLDER",
        "MIXPANEL_TOKEN": "PLACEHOLDER",
        "REVENUECAT_API_KEY_IOS": "PLACEHOLDER",
        "REVENUECAT_API_KEY_ANDROID": "PLACEHOLDER",
        "GOOGLE_MAPS_API_KEY_IOS": "PLACEHOLDER",
        "GOOGLE_MAPS_API_KEY_ANDROID": "PLACEHOLDER"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "buildConfiguration": "Debug"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "development",
        "API_URL": "http://localhost:3000"
      },
      "channel": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "API_URL": "https://luma-v1-production.up.railway.app"
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "ios": {
        "buildConfiguration": "Release",
        "autoIncrement": true
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "production",
        "API_URL": "https://luma-v1-production.up.railway.app"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "APPLE_ID_PLACEHOLDER",
        "ascAppId": "ASC_APP_ID_PLACEHOLDER",
        "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}

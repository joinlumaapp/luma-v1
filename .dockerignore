# ─── Dependencies (will be installed in container) ───────────
node_modules
**/node_modules

# ─── Git ─────────────────────────────────────────────────────
.git
.github
.gitignore

# ─── IDE & Editor ────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*~

# ─── Documentation ───────────────────────────────────────────
*.md
LICENSE
docs/

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── Mobile App (not needed for backend image) ──────────────
apps/mobile
android/
ios/

# ─── Infrastructure & IaC ───────────────────────────────────
infrastructure
terraform/
*.tfstate
*.tfstate.*
.terraform/

# ─── Claude Code ─────────────────────────────────────────────
.claude

# ─── Build Artifacts (will be rebuilt in container) ──────────
dist
**/dist
build
coverage
**/coverage
*.tsbuildinfo

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Docker (prevent recursive context) ─────────────────────
docker-compose*.yml
.dockerignore

# ─── Test Files (not needed in production image) ─────────────
**/*.spec.ts
**/*.test.ts
**/*.e2e-spec.ts
**/test
**/__tests__
**/__mocks__
jest.config.*

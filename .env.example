# LUMA V1 — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env files to git!

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://luma:password@localhost:5432/luma_dev

# Redis
REDIS_URL=redis://localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_EXPIRY_DAYS=7

# Twilio (SMS Verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# AWS — Core
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS — S3 (Photo/Media Storage)
AWS_S3_BUCKET=luma-photos-dev
AWS_S3_VOICE_BUCKET=luma-voice-dev

# AWS — CloudFront (CDN)
AWS_CLOUDFRONT_URL=
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# AWS — Rekognition (Selfie Verification)
AWS_REKOGNITION_COLLECTION_ID=luma-faces-dev

# AWS — SES (Transactional Email)
AWS_SES_FROM_EMAIL=noreply@luma.app
AWS_SES_REGION=eu-west-1

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Apple IAP
APPLE_SHARED_SECRET=

# Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=

# Sentry (Error Tracking)
SENTRY_DSN=

# Analytics
MIXPANEL_TOKEN=

# WebRTC (TURN/STUN)
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=
